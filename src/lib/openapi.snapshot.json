{
  "openapi": "3.0.0",
  "info": {
    "title": "dpsim-api",
    "version": "0.1.0"
  },
  "paths": {
    "/readyz": {
      "get": {
        "description": "Readiness probe — returns 200 only when all critical dependencies are reachable: redis (rate-limit + sim store), PG (audit log + user store; skipped when DATABASE_URL unset), and AMQP (worker queue). Returns 503 with the per-component breakdown when any check fails. Point kubernetes readinessProbe at this instead of /healthz.",
        "operationId": "get_readyz",
        "responses": {
          "default": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyzResponse"
                }
              }
            }
          }
        }
      }
    },
    "/simulation": {
      "get": {
        "description": "List simulations. Pagination via `?limit=N&offset=N` (default 50, max 500). Optional filters: `?status=queued|running|done|failed|canceled`, `?domain=SP|DP|EMT`, `?model_id=<id>`. Sort via `?sort=simulation_id|created_at|status|domain` + `?order=asc|desc` (default `created_at desc`). Filters + sort require PG — they are ignored on the redis fallback path.",
        "operationId": "get_simulations",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0,
              "nullable": true
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0,
              "nullable": true
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "domain",
            "in": "query",
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "model_id",
            "in": "query",
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimulationArray"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "post": {
        "description": "Create a new simulation",
        "operationId": "post_simulation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SimulationForm"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Simulation"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/simulation/bulk": {
      "post": {
        "description": "Submit multiple simulations in one request. Each item is validated + queued independently; the response reports per-item success/failure so a partially-successful batch still delivers the queued sims. Capped at 500 items per request.",
        "operationId": "post_bulk_simulation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkSubmitRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkSubmitResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/simulation/{id}/cancel": {
      "post": {
        "description": "Cancel a simulation. Sets a redis flag `sim:<id>:canceled` that the worker checks before starting work. For queued jobs the worker acks the AMQP message and moves on. For already-running jobs the cancel is best-effort — the current sim.run() can't be interrupted mid-step, but the post-run logging path skips uploading results when the flag is set. Idempotent: calling twice returns the same response.",
        "operationId": "post_cancel_simulation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/simulation/{id}/retry": {
      "post": {
        "description": "v1.2.7 — re-submit a prior simulation under a fresh id. The source simulation is read from redis; its parameters become a new SimulationForm which is parsed through the normal validate + queue path. Useful after a `failed` result (user wants to rerun same params) or to replay a deterministic regression case.\n\n404 if the source id is unknown. 502 when AMQP publish fails. 400 when the replayed params no longer pass validation (e.g. because the referenced model_id has been deleted from file-service).\n\nThe new sim has its own id, trace_id, and results_id — nothing ties it back to the source beyond the request that triggered it. Audit log records both ids so forensics can link them.",
        "operationId": "post_retry_simulation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Simulation"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/simulation/{id}": {
      "get": {
        "description": "Get the details for a simulation",
        "operationId": "get_simulation_id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Simulation"
                }
              }
            }
          }
        }
      }
    },
    "/topology/{model_id}": {
      "get": {
        "operationId": "crate_topology_get_topology",
        "parameters": [
          {
            "name": "model_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TopologyResponse"
                }
              }
            }
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ReadyzResponse": {
        "description": "Body of /readyz so each component's state is machine-readable.",
        "type": "object",
        "required": [
          "amqp",
          "postgres",
          "ready",
          "redis"
        ],
        "properties": {
          "ready": {
            "type": "boolean"
          },
          "redis": {
            "type": "boolean"
          },
          "postgres": {
            "type": "boolean"
          },
          "amqp": {
            "type": "boolean"
          }
        }
      },
      "SimulationArray": {
        "description": "Paged list of simulations.\n\n`total` is the full count available on the server (useful for paging UI); `limit` + `offset` echo back the effective query (may be clamped from the request).",
        "type": "object",
        "required": [
          "simulations"
        ],
        "properties": {
          "simulations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SimulationSummary"
            }
          },
          "total": {
            "default": 0,
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "limit": {
            "default": 0,
            "type": "integer",
            "format": "uint32",
            "minimum": 0.0
          },
          "offset": {
            "default": 0,
            "type": "integer",
            "format": "uint32",
            "minimum": 0.0
          }
        }
      },
      "SimulationSummary": {
        "type": "object",
        "required": [
          "model_id",
          "simulation_id",
          "simulation_type"
        ],
        "properties": {
          "simulation_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "model_id": {
            "type": "string"
          },
          "simulation_type": {
            "$ref": "#/components/schemas/SimulationType"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "domain": {
            "allOf": [
              {
                "$ref": "#/components/schemas/DomainType"
              }
            ],
            "nullable": true
          },
          "engine": {
            "allOf": [
              {
                "$ref": "#/components/schemas/EngineType"
              }
            ],
            "nullable": true
          }
        }
      },
      "SimulationType": {
        "description": "Enum for the various Simulation types",
        "type": "string",
        "enum": [
          "Powerflow",
          "Outage"
        ]
      },
      "DomainType": {
        "description": "Enum for the various Simulation types",
        "type": "string",
        "enum": [
          "SP",
          "DP",
          "EMT"
        ]
      },
      "EngineType": {
        "description": "Simulation engine selection (Phase 4 dual-engine UX).\n\ndpsim      — native DP/EMT/SP simulator (default, backward compatible). pandapower — CIM → pp.runpp() steady-state only, much faster for PF. both       — runs pandapower first (quick reference) then dpsim; UI can diff the two CSVs.",
        "type": "string",
        "enum": [
          "dpsim",
          "pandapower",
          "both"
        ]
      },
      "Simulation": {
        "description": "Struct for encapsulation Simulation details",
        "type": "object",
        "required": [
          "domain",
          "error",
          "finaltime",
          "load_profile_id",
          "model_id",
          "results_data",
          "results_id",
          "simulation_id",
          "simulation_type",
          "solver",
          "timestep"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "load_profile_id": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "results_id": {
            "type": "string"
          },
          "results_data": {
            "type": "string"
          },
          "simulation_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "simulation_type": {
            "$ref": "#/components/schemas/SimulationType"
          },
          "domain": {
            "$ref": "#/components/schemas/DomainType"
          },
          "solver": {
            "$ref": "#/components/schemas/SolverType"
          },
          "timestep": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "finaltime": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "trace_id": {
            "default": "",
            "type": "string"
          },
          "engine": {
            "default": "dpsim",
            "allOf": [
              {
                "$ref": "#/components/schemas/EngineType"
              }
            ]
          }
        }
      },
      "SolverType": {
        "description": "Enum for the various Solver types",
        "type": "string",
        "enum": [
          "MNA",
          "DAE",
          "NRP"
        ]
      },
      "SimulationForm": {
        "title": "Form for submitting a new Simulation",
        "description": "## Parameters: * simulation_type - String - must be one of \"Powerflow\", \"Outage\" * load_profile_id - String - must be a valid id that exists in the associated sogno file service * model_id - String - must be a valid id that exists in the associated sogno file service",
        "type": "object",
        "required": [
          "domain",
          "finaltime",
          "load_profile_id",
          "model_id",
          "simulation_type",
          "solver",
          "timestep"
        ],
        "properties": {
          "simulation_type": {
            "$ref": "#/components/schemas/SimulationType"
          },
          "model_id": {
            "type": "string"
          },
          "load_profile_id": {
            "type": "string"
          },
          "domain": {
            "$ref": "#/components/schemas/DomainType"
          },
          "solver": {
            "$ref": "#/components/schemas/SolverType"
          },
          "timestep": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "finaltime": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "outage_component": {
            "description": "Optional — name (mRID or name attribute) of a CIM ACLineSegment to remove before sim.run(). Leave empty / None for a baseline simulation. P3.4 outage MVP.",
            "type": "string",
            "nullable": true
          },
          "load_factor": {
            "description": "Optional — multiplier applied to every CIM EnergyConsumer P/Q before sim.run(). 1.0 = baseline, 1.5 = heavier load, 0.5 = lighter. Worker mutates the SV file so CIMReader sees the scaled values. P3.3 load-profile MVP (scalar, not time-series).",
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "load_factor_series": {
            "description": "Optional — time-series variant of load_factor. Each point is [t_sec, factor]; worker picks an effective scalar (max for Powerflow stress-tests, linearly-interpolated end-of-run value for DP/EMT) and applies it with _apply_load_factor. Per-step time-stepping isn't exposed by dpsim's Python API so this is a pragmatic approximation — see docs/44 §X for the scope note.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LoadFactorPoint"
            },
            "nullable": true
          },
          "engine": {
            "description": "Simulation engine (Phase 4). dpsim is backward-compatible default. `pandapower` runs pp.runpp() via the PISA adapter; `both` runs pp first then dpsim so the UI can compare the two. The worker dispatches on `parameters.engine` in the AMQP payload.",
            "default": "dpsim",
            "allOf": [
              {
                "$ref": "#/components/schemas/EngineType"
              }
            ]
          }
        }
      },
      "LoadFactorPoint": {
        "type": "object",
        "required": [
          "factor",
          "t_sec"
        ],
        "properties": {
          "t_sec": {
            "type": "number",
            "format": "double"
          },
          "factor": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "BulkSubmitResponse": {
        "type": "object",
        "required": [
          "failed",
          "results",
          "submitted"
        ],
        "properties": {
          "submitted": {
            "type": "integer",
            "format": "uint",
            "minimum": 0.0
          },
          "failed": {
            "type": "integer",
            "format": "uint",
            "minimum": 0.0
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BulkSubmitItem"
            }
          }
        }
      },
      "BulkSubmitItem": {
        "description": "Per-item outcome for /simulation/bulk. Either `simulation` is populated (submitted + queued) or `error` is (validation / AMQP failure). `index` mirrors the request-array position so the client can correlate.",
        "type": "object",
        "required": [
          "index"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "format": "uint",
            "minimum": 0.0
          },
          "simulation": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Simulation"
              }
            ],
            "nullable": true
          },
          "error": {
            "type": "string",
            "nullable": true
          },
          "code": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "BulkSubmitRequest": {
        "description": "v1.2.8 — bulk submit request. Typical use: outage sweep or N-1 contingency study (one form per outage component).",
        "type": "object",
        "required": [
          "simulations"
        ],
        "properties": {
          "simulations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SimulationForm"
            }
          }
        }
      },
      "CancelResponse": {
        "description": "Response body for POST /simulation/<id>/cancel.",
        "type": "object",
        "required": [
          "canceled",
          "simulation_id",
          "status"
        ],
        "properties": {
          "simulation_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "canceled": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "TopologyResponse": {
        "type": "object",
        "required": [
          "branches",
          "buses",
          "model_id"
        ],
        "properties": {
          "model_id": {
            "type": "string"
          },
          "buses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "branches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TopologyBranch"
            }
          }
        }
      },
      "TopologyBranch": {
        "type": "object",
        "required": [
          "bus_from",
          "bus_to",
          "kind",
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "bus_from": {
            "type": "string"
          },
          "bus_to": {
            "type": "string"
          },
          "kind": {
            "description": "\"line\" | \"transformer\" | \"switch\".",
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "description": "JWT returned by POST /auth/login. Supply as `Authorization: Bearer <token>`.",
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}