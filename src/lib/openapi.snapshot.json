{
  "openapi": "3.0.0",
  "info": {
    "title": "dpsim-api",
    "version": "0.1.0"
  },
  "paths": {
    "/simulation": {
      "get": {
        "description": "List the simulations",
        "operationId": "get_simulations",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimulationArray"
                }
              }
            }
          }
        }
      },
      "post": {
        "description": "Create a new simulation",
        "operationId": "post_simulation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SimulationForm"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Simulation"
                }
              }
            }
          }
        }
      }
    },
    "/simulation/{id}": {
      "get": {
        "description": "Get the details for a simulation",
        "operationId": "get_simulation_id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Simulation"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SimulationArray": {
        "description": "Struct for encapsulation Simulation details",
        "type": "object",
        "required": [
          "simulations"
        ],
        "properties": {
          "simulations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SimulationSummary"
            }
          }
        }
      },
      "SimulationSummary": {
        "type": "object",
        "required": [
          "model_id",
          "simulation_id",
          "simulation_type"
        ],
        "properties": {
          "simulation_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "model_id": {
            "type": "string"
          },
          "simulation_type": {
            "$ref": "#/components/schemas/SimulationType"
          }
        }
      },
      "SimulationType": {
        "description": "Enum for the various Simulation types",
        "type": "string",
        "enum": [
          "Powerflow",
          "Outage"
        ]
      },
      "Simulation": {
        "description": "Struct for encapsulation Simulation details",
        "type": "object",
        "required": [
          "domain",
          "error",
          "finaltime",
          "load_profile_id",
          "model_id",
          "results_data",
          "results_id",
          "simulation_id",
          "simulation_type",
          "solver",
          "timestep"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "load_profile_id": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "results_id": {
            "type": "string"
          },
          "results_data": {
            "type": "string"
          },
          "simulation_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "simulation_type": {
            "$ref": "#/components/schemas/SimulationType"
          },
          "domain": {
            "$ref": "#/components/schemas/DomainType"
          },
          "solver": {
            "$ref": "#/components/schemas/SolverType"
          },
          "timestep": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "finaltime": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "trace_id": {
            "default": "",
            "type": "string"
          }
        }
      },
      "DomainType": {
        "description": "Enum for the various Simulation types",
        "type": "string",
        "enum": [
          "SP",
          "DP",
          "EMT"
        ]
      },
      "SolverType": {
        "description": "Enum for the various Solver types",
        "type": "string",
        "enum": [
          "MNA",
          "DAE",
          "NRP"
        ]
      },
      "SimulationForm": {
        "title": "Form for submitting a new Simulation",
        "description": "## Parameters: * simulation_type - String - must be one of \"Powerflow\", \"Outage\" * load_profile_id - String - must be a valid id that exists in the associated sogno file service * model_id - String - must be a valid id that exists in the associated sogno file service",
        "type": "object",
        "required": [
          "domain",
          "finaltime",
          "load_profile_id",
          "model_id",
          "simulation_type",
          "solver",
          "timestep"
        ],
        "properties": {
          "simulation_type": {
            "$ref": "#/components/schemas/SimulationType"
          },
          "model_id": {
            "type": "string"
          },
          "load_profile_id": {
            "type": "string"
          },
          "domain": {
            "$ref": "#/components/schemas/DomainType"
          },
          "solver": {
            "$ref": "#/components/schemas/SolverType"
          },
          "timestep": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "finaltime": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "outage_component": {
            "description": "Optional — name (mRID or name attribute) of a CIM ACLineSegment to remove before sim.run(). Leave empty / None for a baseline simulation. P3.4 outage MVP.",
            "type": "string",
            "nullable": true
          },
          "load_factor": {
            "description": "Optional — multiplier applied to every CIM EnergyConsumer P/Q before sim.run(). 1.0 = baseline, 1.5 = heavier load, 0.5 = lighter. Worker mutates the SV file so CIMReader sees the scaled values. P3.3 load-profile MVP (scalar, not time-series).",
            "type": "number",
            "format": "double",
            "nullable": true
          }
        }
      }
    }
  }
}