{
  "name": "dpsim-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web UI for the DPsim service stack (dpsim-api + worker)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "gen:types": "npm run gen:types:snapshot",
    "gen:types:live": "openapi-typescript ${DPSIM_API_URL:-http://localhost:8000}/openapi.json -o src/lib/types.gen.ts",
    "gen:types:snapshot": "openapi-typescript src/lib/openapi.snapshot.json -o src/lib/types.gen.ts",
    "gen:snapshot": "curl -sfL ${DPSIM_API_URL:-http://localhost:8000}/openapi.json -o src/lib/openapi.snapshot.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@xyflow/react": "^12.10.2",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "redis": "^4.7.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
